{
  "name": "example-project",
  "version": 1,
  "description": "Example ADP workspace manifest for mapping a target project to runtimes and validation.",
  "projects": [
    {
      "name": "app",
      "path": "app",
      "runtime": "agent",
      "sync": true,
      "devcontainer": "optional",
      "validation": [
        "pnpm test",
        "pnpm exec playwright test"
      ]
    }
  ],
  "tasks": [
    {
      "name": "before-large-agent-task",
      "runtime": "agent",
      "risk": "high",
      "owner": "platform-maintainer",
      "review_cadence": "per-task",
      "due": "2099-12-31",
      "requires_snapshot": true,
      "snapshot": "before-large-agent-task",
      "validation": [
        "git status --short",
        "pnpm test"
      ]
    }
  ]
}
