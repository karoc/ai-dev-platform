{
  "name": "recipe-workspace",
  "version": 1,
  "description": "Multi-scenario ADP workspace recipes for low-risk maintenance, frontend browser acceptance, backend validation, and high-risk agent work.",
  "projects": [
    {
      "name": "frontend-app",
      "path": "frontend-app",
      "runtime": "frontend",
      "sync": true,
      "devcontainer": "optional",
      "validation": [
        "pnpm install",
        "pnpm test",
        "pnpm exec playwright test"
      ]
    },
    {
      "name": "backend-api",
      "path": "backend-api",
      "runtime": "backend",
      "sync": true,
      "devcontainer": "optional",
      "validation": [
        "uv sync",
        "uv run pytest",
        "uv run ruff check ."
      ]
    },
    {
      "name": "agent-workspace",
      "path": "agent-workspace",
      "runtime": "agent",
      "sync": true,
      "devcontainer": "optional",
      "validation": [
        "git status --short",
        "pnpm test"
      ]
    }
  ],
  "milestones": [
    {
      "name": "frontend-acceptance",
      "description": "Browser-facing acceptance evidence before frontend release handoff.",
      "runtime": "frontend",
      "snapshot": "milestone-frontend-acceptance",
      "tasks": [
        "frontend-browser-acceptance"
      ]
    },
    {
      "name": "agent-refactor-safety",
      "description": "Snapshot checkpoint before broad agent runtime changes.",
      "runtime": "agent",
      "snapshot": "milestone-agent-refactor-safety",
      "tasks": [
        "broad-agent-refactor"
      ]
    }
  ],
  "evaluations": [
    {
      "name": "frontend-acceptance-eval",
      "description": "Plan-only evaluation hook for browser-facing release evidence.",
      "project": "frontend-app",
      "runtime": "frontend",
      "cadence": "per-change",
      "metrics": [
        "browser-tests-pass",
        "visual-regressions-reviewed",
        "sync-hygiene-reviewed"
      ],
      "commands": [
        "pnpm exec playwright test",
        "git diff --check"
      ],
      "tasks": [
        "frontend-browser-acceptance"
      ]
    },
    {
      "name": "agent-safety-eval",
      "description": "Plan-only evaluation hook for high-risk agent work.",
      "project": "agent-workspace",
      "runtime": "agent",
      "cadence": "per-task",
      "metrics": [
        "snapshot-ready-or-waived",
        "validation-pass",
        "rollback-path-reviewed"
      ],
      "commands": [
        "git status --short",
        "git diff --check",
        "pnpm test"
      ],
      "tasks": [
        "broad-agent-refactor"
      ]
    }
  ],
  "tasks": [
    {
      "name": "docs-copy-edit",
      "project": "agent-workspace",
      "runtime": "agent",
      "risk": "low",
      "owner": "docs-reviewer",
      "review_cadence": "weekly",
      "due": "2099-12-31",
      "requires_snapshot": false,
      "validation": [
        "git diff --check",
        "git status --short"
      ]
    },
    {
      "name": "frontend-browser-acceptance",
      "milestone": "frontend-acceptance",
      "evaluation": "frontend-acceptance-eval",
      "project": "frontend-app",
      "runtime": "frontend",
      "risk": "normal",
      "owner": "frontend-reviewer",
      "review_cadence": "per-change",
      "due": "2099-12-31",
      "requires_snapshot": false,
      "validation": [
        "pnpm install",
        "pnpm exec playwright test"
      ]
    },
    {
      "name": "backend-validation-pass",
      "project": "backend-api",
      "runtime": "backend",
      "risk": "normal",
      "owner": "backend-reviewer",
      "review_cadence": "per-change",
      "due": "2099-12-31",
      "requires_snapshot": false,
      "validation": [
        "uv sync",
        "uv run pytest",
        "uv run ruff check ."
      ]
    },
    {
      "name": "broad-agent-refactor",
      "milestone": "agent-refactor-safety",
      "evaluation": "agent-safety-eval",
      "project": "agent-workspace",
      "runtime": "agent",
      "risk": "high",
      "owner": "agent-reviewer",
      "review_cadence": "per-task",
      "due": "2099-12-31",
      "requires_snapshot": true,
      "snapshot": "before-broad-agent-refactor",
      "validation": [
        "git status --short",
        "git diff --check",
        "pnpm test"
      ]
    }
  ]
}
